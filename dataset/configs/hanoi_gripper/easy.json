{
    "domain_name": "hanoi_gripper",
    "name_extension": "gen_test_2_1000",
    "num_sequences": 1000,
    "sequence_length_method": "planner",
    "num_img_per_sequence": [10, 10],
    "max_img_per_sequence": 15,
    "train_ratio": 0.8,

    "train_num_discs_range": [2, 4],
    "test_num_discs_range": [5, 5],
    "train_num_pegs_range": [3, 3],
    "test_num_pegs_range": [3, 3],
    "train_jitter_pos_xy" : [0.0, 0.0],
    "test_jitter_pos_xy" : [0.0, 0.00],
    "train_jitter_size_xy" : [0.0, 0.0],
    "test_jitter_size_xy" : [0.0, 0.0],
    "train_color_range": [0.0, 1.0],
    "test_color_range": [0.0, 1.0],

    "output_dir": "output",
    "render_annotated_images": false,
    "use_planner": true,
    "interpolation": {
        "use_interpolation": false,
        "method": "linear",
        "num_frames": 5
    },


    "object_classes": ["peg", "disc", "robot"],
    "relationship_classes": ["clear", "on", "smaller", "handempty", "handfull", "holding"],
    "action_name_classes": ["stack", "unstack"]
}