{
    "domain_name": "dominoes",
    "name_extension": "1000",
    "num_sequences": 1000,
    "sequence_length_method": "planner",
    "num_img_per_sequence": [10, 10],
    "max_img_per_sequence": 30,
    "train_ratio": 0.8,

    "train_num_piles_range": [2, 7],
    "test_num_piles_range": [2, 7],
    "train_num_dominoes_range": [3, 5],
    "test_num_dominoes_range": [3, 5],
    "train_color_range": [0.0, 1.0],
    "test_color_range": [0.0, 1.0],
    "training_static_color": false,
    "randomize_x_position_of_piles": true,


    "train_jitter_pos_xy" : [0.0, 0.0],
    "test_jitter_pos_xy" : [0.0, 0.0],
    "train_jitter_size_xy" : [0.0, 0.0],
    "test_jitter_size_xy" : [0.0, 0.0],


    "output_dir": "output",
    "render_realistically": false,
    "render_annotated_images": false,
    "use_planner": true,
    "interpolation": {
        "use_interpolation": false,
        "method": "linear",
        "num_frames": 5
    },


    "object_classes": ["domino", "robot", "table"],
    "relationship_classes": [
        "on",
        "vertically",
        "horizontally",
        "ontable",
        "left",
        "right",
        "clear_top",
        "clear_top_left",
        "clear_top_right",
        "clear_left",
        "clear_right",
        "handempty",
        "handfull",
        "holding"
    ],
    "action_name_classes": [
        "pickup_lc",
        "pickup_rc",
        "putdown_lc",
        "putdown_rc",
        "rotate_vertically",
        "rotate_horizontally",
        "stack_horizontally_lh_rh",
        "stack_horizontally_l_rh",
        "stack_horizontally_lh_r",
        "stack_horizontally_l_r",
        "stack_vertically_lhv_rhv",
        "stack_vertically_lh_rhv",
        "stack_vertically_l_rhv",
        "stack_vertically_lhv_rh",
        "stack_vertically_lh_rh",
        "stack_vertically_l_rh",
        "stack_vertically_lhv_r",
        "stack_vertically_lh_r",
        "stack_vertically_l_r",
        "unstack_vertically_lv_rv",
        "unstack_vertically_lv_r",
        "unstack_vertically_l_rv",
        "unstack_vertically_l_r",
        "unstack_horizontally_lh_rh",
        "unstack_horizontally_l_rh",
        "unstack_horizontally_lh_r",
        "unstack_horizontally_l_r"
    ]
}