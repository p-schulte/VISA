;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;; dominoes domain
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(define (domain dominoes)
    (:requirements :strips :typing)
    (:types domino robot table)
    (:predicates  ; on, vertically, horizontally, ontable, left, right, clear_top, clear_top_left, clear_top_right, clear_left, clear_right
        (on ?x - domino ?y - domino)
        (vertically ?x - domino)
        (horizontally ?x - domino)
        (ontable ?x - domino)
        (left ?x - domino ?y - domino) ; x is left of y
        (right ?x - domino ?y - domino)  ; x is right of y
        (clear_top ?x - domino) ; for horizontal blocks
        (clear_top_left ?x - domino) ; for vertical blocks
        (clear_top_right ?x - domino) ; for vertical blocks
        (clear_left ?x - domino) 
        (clear_right ?x - domino)
        (handempty ?x - robot)
        (handfull ?x - robot)
        (holding ?x - domino)


        ; action literals
        (pickup_lc ?x - domino) ; left clear
        (pickup_rc ?x - domino) ; right clear   

        (putdown_lc ?x - domino) ; left clear
        (putdown_rc ?x - domino) ; right clear

        (rotate_vertically ?x - domino)
        (rotate_horizontally ?x - domino)


        (stack_horizontally_lh_rh ?x - domino ?dl - domino ?dr - domino) ; both sides have a neighbor
        (stack_horizontally_l_rh ?x - domino ?dl - domino ?dr - domino) ; only right side has neighbor
        (stack_horizontally_lh_r ?x - domino ?dl - domino ?dr - domino) ; only left side has neighbor
        (stack_horizontally_l_r ?x - domino ?dl - domino ?dr - domino) ; no neighbors on either side
        

        (stack_vertically_lhv_rhv ?x - domino ?y - domino) ; left all, right all
        (stack_vertically_lh_rhv ?x - domino ?y - domino) ; left horizontal, right all
        (stack_vertically_l_rhv ?x - domino ?y - domino) ; left none, right all
        (stack_vertically_lhv_rh ?x - domino ?y - domino) ; left all, right horizontal
        (stack_vertically_lh_rh ?x - domino ?y - domino) ; left horizontal, right horizontal
        (stack_vertically_l_rh ?x - domino ?y - domino) ; left none, right horizontal
        (stack_vertically_lhv_r ?x - domino ?y - domino) ; left all, right none
        (stack_vertically_lh_r ?x - domino ?y - domino) ; left horizontal, right none
        (stack_vertically_l_r ?x - domino ?y - domino) ; left none, right none
        
        
        (unstack_vertically_lv_rv ?x - domino) ; left vertical, right vertical (neighbors)
        (unstack_vertically_lv_r ?x - domino) ; left vertical, right none (neighbors)
        (unstack_vertically_l_rv ?x - domino) ; left none, right vertical (neighbors)
        (unstack_vertically_l_r ?x - domino) ; left none, right none (neighbors)
        

        (unstack_horizontally_lh_rh ?x - domino) ; left horizontal, right horizontal (neighbors)
        (unstack_horizontally_l_rh ?x - domino) ; left none, right horizontal (neighbors)
        (unstack_horizontally_lh_r ?x - domino) ; left horizontal, right none (neighbors)
        (unstack_horizontally_l_r ?x - domino) ; left none, right none (neighbors)
    )

    ; (:actions pickup_lc pickup_rc putdown_lc putdown_rc stack_horizontally_lh_rh stack_horizontally_l_rh stack_horizontally_lh_r stack_horizontally_l_r stack_vertically_lhv_rhv stack_vertically_lh_rhv stack_vertically_l_rhv stack_vertically_lhv_rh stack_vertically_lh_rh stack_vertically_l_rh stack_vertically_lhv_r stack_vertically_lh_r stack_vertically_l_r unstack_vertically_lv_rv unstack_vertically_lv_r unstack_vertically_l_rv unstack_vertically_l_r unstack_horizontally_lh_rh unstack_horizontally_lh_r unstack_horizontally_l_rh unstack_horizontally_l_r rotate_vertically rotate_horizontally)

    (:action pickup_lc
        :parameters (?x - domino ?y - domino ?robot - robot)
        :precondition (and
            (pickup_lc ?x) 
            (vertically ?x)
            (vertically ?y)
            (ontable ?x) 
            (ontable ?y)
            (handempty ?robot)
            (clear_top_left ?x)
            (clear_top_right ?x)
            (clear_left ?x)
            (not (clear_right ?x))
            (not (clear_left ?y))
            (left ?x ?y)
            (right ?y ?x)
        )
        :effect (and
            (vertically ?x)
            (vertically ?y)
            (not (ontable ?x))
            (not (handempty ?robot))
            (handfull ?robot)
            (holding ?x)
            (not (clear_top_left ?x))
            (not (clear_top_right ?x))
            (not (clear_left ?x))
            (not (clear_right ?x))
            (not (left ?x ?y))
            (not (right ?y ?x))
            (clear_left ?y)
        )
    )
    (:action pickup_rc
        :parameters (?x - domino ?y - domino ?robot - robot)
        :precondition (and
            (pickup_rc ?x) 
            (vertically ?x)
            (vertically ?y)
            (ontable ?x) 
            (ontable ?y)
            (handempty ?robot)
            (clear_top_left ?x)
            (clear_top_right ?x)
            (clear_right ?x)
            (not (clear_left ?x))
            (not (clear_right ?y))
            (left ?y ?x)
            (right ?x ?y)
        )
        :effect (and
            (vertically ?x)
            (vertically ?y)
            (not (ontable ?x))
            (not (handempty ?robot))
            (handfull ?robot)
            (holding ?x)
            (not (clear_top_left ?x))
            (not (clear_top_right ?x))
            (not (clear_left ?x))
            (not (clear_right ?x))
            (not (left ?y ?x))
            (not (right ?x ?y))
            (clear_right ?y)
        )
    )







    (:action putdown_lc
        :parameters (?x - domino ?y - domino ?robot - robot)
        :precondition (and 
            (putdown_lc ?x)
            (holding ?x)
            (handfull ?robot)
            (vertically ?x)
            (vertically ?y)
            (ontable ?y)
            (clear_left ?y)
        )
        :effect (and 
            (not (holding ?x))
            (handempty ?robot)
            (vertically ?x)
            (vertically ?y)
            (clear_top_left ?x)
            (clear_top_right ?x)
            (not (clear_right ?x))
            (clear_left ?x)
            (not (clear_left ?y))
            (left ?x ?y)
            (right ?y ?x)
            (not (handfull ?robot))
            (ontable ?x))
    )
    (:action putdown_rc
        :parameters (?x - domino ?y - domino ?robot - robot)
        :precondition (and 
            (putdown_rc ?x)
            (holding ?x)
            (handfull ?robot)
            (vertically ?x)
            (vertically ?y)
            (ontable ?y)
            (clear_right ?y)
        )
        :effect (and 
            (not (holding ?x))
            (handempty ?robot)
            (vertically ?x)
            (vertically ?y)
            (clear_top_left ?x)
            (clear_top_right ?x)
            (not (clear_left ?x))
            (clear_right ?x)
            (not (clear_right ?y))
            (right ?x ?y)
            (left ?y ?x)
            (not (handfull ?robot))
            (ontable ?x))
    )








    (:action rotate_vertically
        :parameters (?x - domino ?robot - robot)
        :precondition (and 
            (rotate_vertically ?x)
            (holding ?x)
            (horizontally ?x)
            (not (vertically ?x))
            (handfull ?robot)
        )
        :effect (and 
            (holding ?x)
            (not (horizontally ?x))
            (vertically ?x)
            (handfull ?robot)
        )
    )
    (:action rotate_horizontally
        :parameters (?x - domino ?robot - robot)
        :precondition (and 
            (rotate_horizontally ?x)
            (holding ?x)
            (vertically ?x)
            (not (horizontally ?x))
            (handfull ?robot)
        )
        :effect (and 
            (holding ?x)
            (not (vertically ?x))
            (horizontally ?x)
            (handfull ?robot)
        )
    )








    (:action stack_horizontally_lh_rh
        :parameters (?x - domino ?dl - domino ?dr - domino ?r - domino ?l - domino ?robot - robot)
        :precondition (and 
            (stack_horizontally_lh_rh ?x ?dl ?dr)
            (holding ?x)
            (horizontally ?x)
            (horizontally ?r)
            (horizontally ?l)
            (vertically ?dl)
            (vertically ?dr)
            (left ?dl ?dr)
            (right ?dr ?dl)
            (not (clear_left ?dr))
            (not (clear_right ?dl))
            (not (clear_left ?x))
            (not (clear_right ?x))
            (clear_right ?l)
            (clear_left ?r)
            (on ?l ?dl)
            (on ?r ?dr)
            (clear_top_right ?dl)
            (clear_top_left ?dr)
            (handfull ?robot)
        )
        :effect (and 
            (not (holding ?x))
            (horizontally ?x)
            (horizontally ?r)
            (horizontally ?l)
            (vertically ?dl)
            (vertically ?dr)
            (left ?dl ?dr)
            (right ?dr ?dl)
            (not (clear_left ?dr))
            (not (clear_right ?dl))
            (not (clear_left ?x))
            (not (clear_right ?x))
            (not (clear_right ?l))
            (not (clear_left ?r))
            (not (clear_top_right ?dl))
            (not (clear_top_left ?dr))
            (on ?x ?dl)
            (on ?x ?dr)
            (left ?l ?x)
            (right ?x ?l)
            (left ?x ?r)
            (right ?r ?x)
            (not (handfull ?robot))
            (handempty ?robot)
            (clear_top ?x)
        )
    )
    (:action stack_horizontally_l_rh
        :parameters (?x - domino ?dl - domino ?dr - domino ?r - domino ?robot - robot)
        :precondition (and 
            (stack_horizontally_l_rh ?x ?dl ?dr)
            (holding ?x)
            (horizontally ?x)
            (horizontally ?r)
            (vertically ?dl)
            (vertically ?dr)
            (left ?dl ?dr)
            (right ?dr ?dl)
            (not (clear_left ?dr))
            (not (clear_right ?dl))
            (not (clear_left ?x))
            (not (clear_right ?x))
            (clear_left ?r)
            (on ?r ?dr)
            (clear_top_left ?dl)
            (clear_top_right ?dl)
            (clear_top_left ?dr)
            (handfull ?robot)
        )
        :effect (and 
            (not (holding ?x))
            (horizontally ?x)
            (horizontally ?r)
            (vertically ?dl)
            (vertically ?dr)
            (left ?dl ?dr)
            (right ?dr ?dl)
            (not (clear_left ?dr))
            (not (clear_right ?dl))
            (clear_left ?x)
            (not (clear_right ?x))
            (not (clear_left ?r))
            (clear_top_left ?dl)
            (not (clear_top_right ?dl))
            (not (clear_top_left ?dr))
            (on ?x ?dl)
            (on ?x ?dr)
            (left ?x ?r)
            (right ?r ?x)
            (not (handfull ?robot))
            (handempty ?robot)
            (clear_top ?x)
        )
    )
    (:action stack_horizontally_lh_r 
        :parameters (?x - domino ?dl - domino ?dr - domino ?l - domino ?robot - robot)
        :precondition (and 
            (stack_horizontally_lh_r ?x ?dl ?dr)
            (holding ?x)
            (horizontally ?x)
            (horizontally ?l)
            (vertically ?dl)
            (vertically ?dr)
            (left ?dl ?dr)
            (right ?dr ?dl)
            (not (clear_left ?dr))
            (not (clear_right ?dl))
            (not (clear_left ?x))
            (not (clear_right ?x))
            (clear_right ?l)
            (on ?l ?dl)
            (clear_top_left ?dr)
            (clear_top_right ?dr)
            (clear_top_right ?dl)
            (handfull ?robot)
            (clear_top ?x)
        )
        :effect (and 
            (not (holding ?x))
            (horizontally ?x)
            (horizontally ?l)
            (vertically ?dl)
            (vertically ?dr)
            (left ?dl ?dr)
            (right ?dr ?dl)
            (not (clear_left ?dr))
            (not (clear_right ?dl))
            (not (clear_left ?x))
            (clear_right ?x)
            (not (clear_right ?l))
            (clear_top_right ?dr)
            (not (clear_top_right ?dl))
            (not (clear_top_left ?dr))
            (on ?x ?dl)
            (on ?x ?dr)
            (left ?l ?x)
            (right ?x ?l)
            (not (handfull ?robot))
            (handempty ?robot)
        )
    )
    (:action stack_horizontally_l_r
        :parameters (?x - domino ?dl - domino ?dr - domino ?robot - robot)
        :precondition (and 
            (stack_horizontally_l_r ?x ?dl ?dr)
            (holding ?x)
            (horizontally ?x)
            (vertically ?dl)
            (vertically ?dr)
            (left ?dl ?dr)
            (right ?dr ?dl)
            (not (clear_left ?dr))
            (not (clear_right ?dl))
            (not (clear_left ?x))
            (not (clear_right ?x))
            (clear_top_left ?dr)
            (clear_top_right ?dr)
            (clear_top_left ?dl)
            (clear_top_right ?dl)
            (handfull ?robot)
        )
        :effect (and 
            (not (holding ?x))
            (horizontally ?x)
            (vertically ?dl)
            (vertically ?dr)
            (left ?dl ?dr)
            (right ?dr ?dl)
            (not (clear_left ?dr))
            (not (clear_right ?dl))
            (clear_left ?x)
            (clear_right ?x)
            (clear_top_right ?dr)
            (clear_top_left ?dl)
            (not (clear_top_right ?dl))
            (not (clear_top_left ?dr))
            (on ?x ?dl)
            (on ?x ?dr)
            (not (handfull ?robot))
            (handempty ?robot)
            (clear_top ?x)
        )
    )
    







    (:action stack_vertically_lhv_rhv
        :parameters (?x - domino ?d - domino ?lh - domino ?rh - domino ?lv - domino ?rv - domino ?robot - robot)
        :precondition (and 
            (stack_vertically_lhv_rhv ?x ?d)
            (holding ?x)
            (vertically ?x)
            (vertically ?lv)
            (vertically ?rv)
            (horizontally ?d)
            (horizontally ?lh)
            (horizontally ?rh)
            (left ?lh ?d)
            (right ?d ?lh)
            (left ?d ?rh)
            (right ?rh ?d)
            (clear_right ?lv)
            (clear_left ?rv)
            (clear_top ?d)
            (on ?lv ?lh)
            (on ?rv ?rh)
            (handfull ?robot)
        )
        :effect (and 
            (not (holding ?x))
            (on ?x ?d)
            (clear_top_left ?x)
            (clear_top_right ?x)
            (not (clear_right ?lv))
            (not (clear_left ?rv))
            (not (clear_right ?x))
            (not (clear_left ?x))
            (right ?x ?lv)
            (left ?lv ?x)
            (left ?x ?rv)
            (right ?rv ?x)
            (not (clear_top ?d))
            (not (handfull ?robot))
            (handempty ?robot)
        )
    )
    (:action stack_vertically_lh_rhv
        :parameters (?x - domino ?d - domino ?lh - domino ?rh - domino ?rv - domino ?robot - robot)
        :precondition (and 
            (stack_vertically_lh_rhv ?x ?d)
            (holding ?x)
            (vertically ?x)
            (vertically ?rv)
            (horizontally ?d)
            (horizontally ?lh)
            (horizontally ?rh)
            (left ?lh ?d)
            (right ?d ?lh)
            (left ?d ?rh)
            (right ?rh ?d)
            (clear_left ?rv)
            (clear_top ?d)
            (clear_top ?lh)
            (on ?rv ?rh)
            (handfull ?robot)
        )
        :effect (and 
            (not (holding ?x))
            (on ?x ?d)
            (clear_top_left ?x)
            (clear_top_right ?x)
            (not (clear_left ?rv))
            (not (clear_right ?x))
            (clear_left ?x)
            (left ?x ?rv)
            (right ?rv ?x)
            (not (clear_top ?d))
            (not (handfull ?robot))
            (handempty ?robot)
        )
    )
    (:action stack_vertically_l_rhv
        :parameters (?x - domino ?d - domino ?rh - domino ?rv - domino ?robot - robot)
        :precondition (and 
            (stack_vertically_l_rhv ?x ?d)
            (holding ?x)
            (vertically ?x)
            (vertically ?rv)
            (horizontally ?d)
            (horizontally ?rh)
            (left ?d ?rh)
            (right ?rh ?d)
            (clear_left ?rv)
            (clear_top ?d)
            (clear_left ?d)
            (on ?rv ?rh)
            (handfull ?robot)
        )
        :effect (and 
            (not (holding ?x))
            (on ?x ?d)
            (clear_top_left ?x)
            (clear_top_right ?x)
            (not (clear_left ?rv))
            (not (clear_right ?x))
            (clear_left ?x)
            (left ?x ?rv)
            (right ?rv ?x)
            (not (clear_top ?d))
            (not (handfull ?robot))
            (handempty ?robot)
        )
    )
    (:action stack_vertically_lhv_rh
        :parameters (?x - domino ?d - domino ?lh - domino ?rh - domino ?lv - domino ?robot - robot)
        :precondition (and 
            (stack_vertically_lhv_rh ?x ?d)
            (holding ?x)
            (vertically ?x)
            (vertically ?lv)
            (horizontally ?d)
            (horizontally ?lh)
            (horizontally ?rh)
            (left ?lh ?d)
            (right ?d ?lh)
            (left ?d ?rh)
            (right ?rh ?d)
            (clear_top ?rh)
            (clear_top ?d)
            (on ?lv ?lh)
            (handfull ?robot)
        )
        :effect (and 
            (not (holding ?x))
            (on ?x ?d)
            (clear_top_left ?x)
            (clear_top_right ?x)
            (not (clear_right ?lv))
            (not (clear_left ?x))
            (right ?x ?lv)
            (left ?lv ?x)
            (clear_right ?x)
            (not (clear_top ?d))
            (not (handfull ?robot))
            (handempty ?robot)
        )
    )
    (:action stack_vertically_lh_rh
        :parameters (?x - domino ?d - domino ?lh - domino ?rh - domino ?robot - robot)
        :precondition (and 
            (stack_vertically_lh_rh ?x ?d)
            (holding ?x)
            (vertically ?x)
            (horizontally ?d)
            (horizontally ?lh)
            (horizontally ?rh)
            (left ?lh ?d)
            (right ?d ?lh)
            (left ?d ?rh)
            (right ?rh ?d)
            (clear_top ?rh)
            (clear_top ?lh)
            (clear_top ?d)
            (handfull ?robot)
        )
        :effect (and 
            (not (holding ?x))
            (on ?x ?d)
            (clear_top_left ?x)
            (clear_top_right ?x)
            (clear_right ?x)
            (clear_left ?x)
            (not (clear_top ?d))
            (not (handfull ?robot))
            (handempty ?robot)
        )
    )
    (:action stack_vertically_l_rh
        :parameters (?x - domino ?d - domino ?rh - domino ?robot - robot)
        :precondition (and 
            (stack_vertically_l_rh ?x ?d)
            (holding ?x)
            (vertically ?x)
            (horizontally ?d)
            (horizontally ?rh)
            (clear_left ?d)
            (left ?d ?rh)
            (right ?rh ?d)
            (clear_top ?rh)
            (clear_top ?d)
            (handfull ?robot)
        )
        :effect (and 
            (not (holding ?x))
            (on ?x ?d)
            (clear_top_left ?x)
            (clear_top_right ?x)
            (clear_right ?x)
            (clear_left ?x)
            (not (clear_top ?d))
            (not (handfull ?robot))
            (handempty ?robot)
        )
    )
    (:action stack_vertically_lhv_r
        :parameters (?x - domino ?d - domino ?lh - domino ?lv - domino ?robot - robot)
        :precondition (and 
            (stack_vertically_lhv_r ?x ?d)
            (holding ?x)
            (vertically ?x)
            (vertically ?lv)
            (horizontally ?d)
            (horizontally ?lh)
            (left ?lh ?d)
            (right ?d ?lh)
            (clear_right ?d)
            (clear_top ?d)
            (on ?lv ?lh)
            (clear_right ?lv)
            (handfull ?robot)
        )
        :effect (and 
            (not (holding ?x))
            (on ?x ?d)
            (clear_top_left ?x)
            (clear_top_right ?x)
            (not (clear_right ?lv))
            (not (clear_left ?x))
            (right ?x ?lv)
            (left ?lv ?x)
            (clear_right ?x)
            (not (clear_top ?d))
            (not (handfull ?robot))
            (handempty ?robot)
        )
    )
    (:action stack_vertically_lh_r
        :parameters (?x - domino ?d - domino ?lh - domino ?robot - robot)
        :precondition (and 
            (stack_vertically_lh_r ?x ?d)
            (holding ?x)
            (vertically ?x)
            (horizontally ?d)
            (horizontally ?lh)
            (left ?lh ?d)
            (right ?d ?lh)
            (clear_right ?d)
            (clear_top ?d)
            (clear_top ?lh)
            (handfull ?robot)
        )
        :effect (and 
            (not (holding ?x))
            (on ?x ?d)
            (clear_top_left ?x)
            (clear_top_right ?x)
            (clear_left ?x)
            (clear_right ?x)
            (not (clear_top ?d))
            (not (handfull ?robot))
            (handempty ?robot)
        )
    )
    (:action stack_vertically_l_r
        :parameters (?x - domino ?d - domino ?robot - robot)
        :precondition (and 
            (stack_vertically_l_r ?x ?d)
            (holding ?x)
            (vertically ?x)
            (horizontally ?d)
            (clear_right ?d)
            (clear_left ?d)
            (clear_top ?d)
            (handfull ?robot)
        )
        :effect (and 
            (not (holding ?x))
            (on ?x ?d)
            (clear_top_left ?x)
            (clear_top_right ?x)
            (clear_left ?x)
            (clear_right ?x)
            (not (clear_top ?d))
            (not (handfull ?robot))
            (handempty ?robot)
        )
    )








    (:action unstack_vertically_lv_rv
        :parameters (?x - domino ?d - domino ?lv - domino ?rv - domino ?robot - robot)
        :precondition (and 
            (unstack_vertically_lv_rv ?x)
            (horizontally ?d)
            (on ?x ?d)
            (vertically ?x)
            (vertically ?lv)
            (vertically ?rv)
            (left ?lv ?x)
            (right ?x ?lv)
            (left ?x ?rv)
            (right ?rv ?x)
            (clear_top_left ?x)
            (clear_top_right ?x)
            (handempty ?robot)
        )
        :effect (and 
            (not (on ?x ?d))
            (not (handempty ?robot))
            (handfull ?robot)
            (holding ?x)
            (not (left ?lv ?x))
            (not (right ?x ?lv))
            (not (left ?x ?rv))
            (not (right ?rv ?x))
            (not (clear_top_left ?x))
            (not (clear_top_right ?x))
